{
  "version": 2,
  "ignoreCommand": "[ \"$VERCEL_ENV\" = \"preview\" ]",
  "regions": ["iad1"],
  "crons": [
    { "path": "/api/cron/tick?maxJobs=1", "schedule": "*/15 * * * *" },
    { "path": "/api/loop-cron-snapshot", "schedule": "5 */2 * * *" }
  ],
  "functions": {
    "api/aave-proxy.js": {
      "maxDuration": 60,
      "regions": ["fra1"]
    },
    "api/*.js": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/api/perps", "destination": "/api/aave-proxy" },
    { "source": "/api/loop-rates", "destination": "/api/aave-proxy?loopRates=1" },
    { "source": "/api/loop-snapshots", "destination": "/api/aave-proxy?loopSnapshots=1" },
    { "source": "/api/loop-cron-snapshot", "destination": "/api/aave-proxy?loopCronSnapshot=1" },
    { "source": "/api/cron/tick", "destination": "/api/sync?cronTick=1" },
    { "source": "/api/cron/status", "destination": "/api/sync?cronStatus=1" },
    { "source": "/api/check-alerts", "destination": "/api/sync?checkAlerts=1" }
  ],
  "headers": [
    {
      "source": "/",
      "headers": [{ "key": "Cache-Control", "value": "no-cache, must-revalidate" }]
    },
    {
      "source": "/index.html",
      "headers": [{ "key": "Cache-Control", "value": "no-cache, must-revalidate" }]
    }
  ]
}
