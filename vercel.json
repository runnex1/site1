{
  "version": 2,
  "ignoreCommand": "[ \"$VERCEL_ENV\" = \"preview\" ]",
  "regions": ["hnd1"],
  "functions": {
    "api/aave-proxy.js": {
      "maxDuration": 60,
      "regions": ["hnd1"]
    },
    "api/*.js": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/api/perps", "destination": "/api/aave-proxy" },
    { "source": "/api/loop-rates", "destination": "/api/aave-proxy?loopRates=1" },
    { "source": "/api/loop-snapshots", "destination": "/api/aave-proxy?loopSnapshots=1" }
  ]
}
